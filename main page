<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Convergence wiki</title>
    <style>
        body, h1, h2, ul, li { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0d0d0d; color: white; }

        .page-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .site-header {
            background-color: #1a1e4a;
            padding: 20px 40px;
            border-bottom: 1px solid #2a2e5a;
        }

        .site-title {
            font-size: 28px;
            font-weight: 300;
        }

        .content-container {
            display: flex;
            flex: 1;
        }

        .sidebar-nav {
            background-color: #1a1e4a;
            width: 250px;
            padding: 40px 20px;
        }

        .sidebar-nav ul { list-style: none; }
        .sidebar-nav li { margin-bottom: 20px; }
        .sidebar-nav a {
            text-decoration: none;
            color: #b0b0b0;
            font-size: 18px;
            transition: 0.2s;
        }
        .sidebar-nav a:hover { color: #ffffff; }

        .main-content {
            flex: 1;
            background-color: #111111;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 20px;
        }

        .section-title {
            font-family: 'Georgia', serif;
            font-weight: normal;
            margin-bottom: 30px;
            font-size: 22px;
        }

        .logo-container {
            width: 100%;
            max-width: 900px;
            text-align: center;
        }

        .logo-container img {
            max-width: 100%;
            height: auto;
            display: block;
            margin: 0 auto;
        }
    </style>
</head>
<body>

    <div class="page-wrapper">
        
        <header class="site-header">
            <h1 class="site-title">The Convergence wiki</h1>
        </header>

        <div class="content-container">
            
            <nav class="sidebar-nav">
                <ul>
                    <li><a href="#">classes</a></li>
                    <li><a href="#">spell runes</a></li>
                    <li><a href="#">upgrade materials</a></li>
                </ul>
            </nav>

            <main class="main-content">
                <div class="logo-container">
                    <img src="elden ring.png" alt="elden ring">
                </div>
            </main>

        </div>
    </div>

</body>
</html>
